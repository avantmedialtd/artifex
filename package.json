{
    "name": "@avantmedia/af",
    "version": "0.0.12",
    "description": "Development utility.",
    "homepage": "https://github.com/avantmedialtd/artifex#readme",
    "bugs": {
        "url": "https://github.com/avantmedialtd/artifex/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/avantmedialtd/artifex.git"
    },
    "license": "MIT",
    "author": "István Antal <istvan@antal.xyz>",
    "keywords": [
        "cli",
        "developer-tools",
        "bun",
        "openspec",
        "dependency-upgrade"
    ],
    "bin": {
        "af": "./af"
    },
    "engines": {
        "node": ">=16"
    },
    "type": "module",
    "files": [
        "af",
        "main.ts",
        "router.ts",
        "bun-upgrade.ts",
        "npm-upgrade.ts",
        "git-worktree.ts",
        "commands/",
        "components/",
        "utils/",
        "resources/",
        "scripts/e2e_tests.ts",
        "atlassian/**/*.ts",
        "jira/**/*.ts",
        "confluence/**/*.ts",
        "!**/*.test.ts"
    ],
    "main": "main.ts",
    "scripts": {
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix",
        "lint:check": "oxlint .",
        "spell:check": "cspell \"**\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@types/node": "^25.0.3",
        "@types/react": "^19.2.7",
        "@vitest/ui": "^4.0.16",
        "cspell": "^9.4.0",
        "oxlint": "^1.36.0",
        "prettier": "^3.7.4",
        "typescript": "^5.9.3",
        "react-devtools-core": "^7.0.1",
        "vitest": "^4.0.16"
    },
    "dependencies": {
        "bun": ">=1.1.0",
        "ink": "^6.6.0",
        "react": "^19.2.3"
    }
}

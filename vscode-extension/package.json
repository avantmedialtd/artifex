{
    "name": "openspec-tasks",
    "displayName": "OpenSpec Tasks",
    "description": "Monitor OpenSpec change tasks in a dedicated panel",
    "version": "0.1.0",
    "publisher": "avantmedia",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/openspec/changes"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "panel": [
                {
                    "id": "openspec",
                    "title": "Changes",
                    "icon": "$(checklist)"
                }
            ]
        },
        "views": {
            "openspec": [
                {
                    "id": "openspecTasks",
                    "name": "Changes"
                }
            ]
        },
        "configuration": {
            "title": "OpenSpec Tasks",
            "properties": {
                "openspecTasks.autoCollapseCompletedSections": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically collapse task sections where all todos are checked"
                }
            }
        },
        "menus": {
            "view/item/context": [
                {
                    "command": "openspecTasks.applyChange",
                    "when": "view == openspecTasks && viewItem =~ /^change-incomplete/",
                    "group": "1_actions"
                },
                {
                    "command": "openspecTasks.archiveChange",
                    "when": "view == openspecTasks && viewItem =~ /^change-complete/",
                    "group": "1_actions"
                },
                {
                    "command": "openspecTasks.copyTitle",
                    "when": "view == openspecTasks && viewItem =~ /with-title$/",
                    "group": "2_copy"
                },
                {
                    "command": "openspecTasks.copyChangeId",
                    "when": "view == openspecTasks && viewItem =~ /^change/",
                    "group": "2_copy"
                }
            ]
        },
        "commands": [
            {
                "command": "openspecTasks.applyChange",
                "title": "Apply Change",
                "icon": "$(play)"
            },
            {
                "command": "openspecTasks.archiveChange",
                "title": "Archive Change",
                "icon": "$(archive)"
            },
            {
                "command": "openspecTasks.copyChangeId",
                "title": "Copy Change ID",
                "icon": "$(copy)"
            },
            {
                "command": "openspecTasks.copyTitle",
                "title": "Copy Title",
                "icon": "$(copy)"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "package": "vsce package",
        "install-extension": "code --install-extension openspec-tasks-0.1.0.vsix"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}

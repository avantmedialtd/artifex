{
    "name": "openspec-tasks",
    "displayName": "OpenSpec Tasks",
    "description": "Monitor OpenSpec change tasks in a dedicated panel",
    "version": "0.1.0",
    "publisher": "avantmedia",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/openspec/changes"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "panel": [
                {
                    "id": "openspec",
                    "title": "Changes",
                    "icon": "$(checklist)"
                }
            ]
        },
        "views": {
            "openspec": [
                {
                    "id": "openspecTasks",
                    "name": "Changes"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}
